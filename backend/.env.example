PORT=8080
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/apex_academy?retryWrites=true&w=majority&appName=Cluster0
# If college/office WiFi blocks Atlas, the server auto-uses in-memory MongoDB in dev.
# Force in-memory only: MONGO_MEMORY_FALLBACK=true
JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_SECRET=your_admin_secret_key
ADMIN_EMAIL=admin@apexacademy.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Apex Admin
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
# Get free TEST keys: https://dashboard.razorpay.com/app/keys
# For local testing WITHOUT Razorpay keys, set:
MOCK_PAYMENTS=true
CLIENT_URL=http://localhost:3001
# Frontend runs on 3001 (port 3000 may be used by another app)
# CLIENT_URL=http://localhost:3000,https://your-domain.com
# CORS_ALLOW_ALL=true

# Email — required for forgot password (Gmail App Password)
# 1. Enable 2-Step Verification on Gmail
# 2. Create App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=apexacademy509@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=Apex Academy <apexacademy509@gmail.com>

# Or use custom SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apexacademy509@gmail.com
# SMTP_PASS=your_app_password

# AWS S3 — optional legacy fallback (Cloudinary is preferred for all files)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=apex-academy-uploads
# Optional: CloudFront or custom domain base URL (no trailing slash)
# AWS_S3_PUBLIC_URL=https://d1234abcd.cloudfront.net

# Cloudinary — required for ALL uploads (images, videos, PDFs & question papers)
# Get keys from https://console.cloudinary.com → Dashboard
CLOUDINARY_URL=cloudinary://YOUR_API_KEY:YOUR_API_SECRET@YOUR_CLOUD_NAME
# Or set separately:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
